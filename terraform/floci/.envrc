# direnv: https://direnv.net/
# Auto-start Floci when entering this directory and export local AWS credentials.

watch_file docker-compose.yml

export COMPOSE_PROJECT_NAME=floci-terraform

# Prefer OrbStack's Docker engine for this playground when available.
# See: https://docs.orbstack.dev/docker/
if command -v orb >/dev/null 2>&1 && ! orb status 2>/dev/null | grep -q '^Running'; then
  echo "direnv: starting OrbStack..."
  orb start >/dev/null 2>&1 || true
fi

if command -v docker >/dev/null 2>&1 && docker context inspect orbstack >/dev/null 2>&1; then
  export DOCKER_CONTEXT=orbstack
fi

export AWS_ENDPOINT_URL=http://localhost:4566
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_DEFAULT_REGION=us-east-1
export AWS_REGION=$AWS_DEFAULT_REGION
export AWS_EC2_METADATA_DISABLED=true

# Floci ECS/EKS run in real Docker mode in docker-compose.yml.
# ECS task containers and EKS k3s containers should join this Compose network.
export FLOCI_DOCKER_NETWORK=${COMPOSE_PROJECT_NAME}_default

# Handy Terraform defaults for local AWS emulators.
export TF_VAR_aws_endpoint_url=$AWS_ENDPOINT_URL
export TF_VAR_aws_region=$AWS_DEFAULT_REGION

if command -v docker >/dev/null 2>&1; then
  if docker info >/dev/null 2>&1; then
    mkdir -p data/eks
    if docker compose up -d >/dev/null 2>&1; then
      echo "direnv: Floci is running via Docker context: ${DOCKER_CONTEXT:-$(docker context show)}"
    else
      echo "direnv: docker compose up failed; run manually with: docker compose up -d"
    fi
  else
    echo "direnv: Docker is not running; start OrbStack and run: docker compose up -d"
  fi
else
  echo "direnv: Docker CLI not found; install OrbStack or Docker to run Floci automatically"
fi
